<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }} | {{ site.name }}</title>
<meta name="description" content="{{ description or site.description }}">
<link rel="canonical" href="{{ site.url }}{{ page.url }}">
<meta name="robots" content="index, follow">
<meta name="theme-color" content="#5a4452">

<!-- Open Graph / SNS共有用 -->
<meta property="og:type" content="{{ ogType or 'website' }}">
<meta property="og:site_name" content="{{ site.name }}">
<meta property="og:title" content="{{ title }} | {{ site.name }}">
<meta property="og:description" content="{{ description or site.description }}">
<meta property="og:url" content="{{ site.url }}{{ page.url }}">
<meta property="og:image" content="{{ ogImage or site.ogImage }}">
<meta property="og:locale" content="ja_JP">
<meta name="twitter:card" content="summary_large_image">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=Noto+Serif+JP:wght@500;700&family=Cormorant+Garamond:wght@500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/blog.css">
{% block head %}{% endblock %}
</head>
<body>

<header>
  <div class="header-inner">
    <a href="/" class="brand">
      <div class="brand-mark">和</div>
      <div>
        <div class="brand-name">東和盛泰株式会社</div>
        <div class="brand-en">TOUWASEITAI CO., LTD.</div>
      </div>
    </a>
    <nav class="nav">
      <a href="/#about">会社案内</a>
      <a href="/#strength">強み</a>
      <a href="/#products">取扱品目</a>
      <a href="/#company">会社概要</a>
      <a href="/blog/" class="is-current">ブログ</a>
      <a href="/#contact">お問い合わせ</a>
    </nav>
    <a href="/#contact" class="header-cta">CONTACT</a>
  </div>
</header>

{{ content | safe }}

<footer>
  <div class="footer-inner">
    <div class="footer-brand">
      <div class="brand-mark">和</div>
      <div>
        <div class="brand-name">東和盛泰株式会社</div>
        <div class="brand-en">TOUWASEITAI CO., LTD.</div>
      </div>
    </div>
    <div class="footer-bottom">
      <div>&copy; 2026 TOUWASEITAI CO., LTD. All Rights Reserved.</div>
      <div>ニット衣料の企画・生産・卸販売</div>
    </div>
  </div>
</footer>

</body>
</html>
